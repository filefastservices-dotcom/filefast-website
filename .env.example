# ============================================
# PHASE 1 — Core Configuration
# ============================================

# MongoDB Atlas connection string (get this from MongoDB Atlas dashboard)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.mongodb.net/filefast?retryWrites=true&w=majority

# Admin login credentials (you choose these)
ADMIN_EMAIL=admin@filefast.in
ADMIN_PASSWORD=ChangeThisToAStrongPassword123!

# Random long secret string used to sign admin login sessions
# Generate one at https://generate-secret.vercel.app/32
JWT_SECRET=replace-this-with-a-random-32-character-string

# Used to build absolute URLs (your live domain once deployed)
NEXT_PUBLIC_SITE_URL=https://filefast.in

# WhatsApp number in international format, no + or spaces
NEXT_PUBLIC_WHATSAPP_NUMBER=919444614182

# ============================================
# PHASE 2 — Payments & Multi-Language
# ============================================

# Razorpay API Key (optional, for online payments)
# Get from: https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY=your_razorpay_test_key_here

# Default language (en, ta, hi)
NEXT_PUBLIC_DEFAULT_LANGUAGE=en

